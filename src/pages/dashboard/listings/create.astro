---
import Layout from "../../../layouts/Layout.astro";
import { Header } from "../../../components/Header";
import { ArrowLeft, Save, Building2, Briefcase, Wrench, Gift, Car, ClipboardList, CheckCircle2 } from "lucide-react";

const { supabase, user, profile } = Astro.locals;
if (!user) {
    return Astro.redirect("/login");
}

let error = "";
let success = false;

// Fetch categories for the select input
const { data: categories } = await supabase
    .from("categories")
    .select("id, name, slug")
    .order('name');

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const title = formData.get("title")?.toString();
    const description = formData.get("description")?.toString();
    const price = formData.get("price")?.toString();
    const location = formData.get("location")?.toString();
    const category_id = formData.get("category_id")?.toString();
    const imageFiles = formData.getAll("images") as File[];
    let image_urls: string[] = [];

    // Extract category-specific details
    const category_details: Record<string, any> = {};
    for (const [key, value] of formData.entries()) {
        if (key.startsWith("details_")) {
            const fieldName = key.replace("details_", "");
            category_details[fieldName] = value;
        }
    }

    if (title) {
        // Handle up to 3 images
        const validImages = imageFiles
            .filter((file) => file.size > 0)
            .slice(0, 3);

        for (const imageFile of validImages) {
            const fileExt = imageFile.name.split(".").pop() || "jpg";
            const fileName = `${crypto.randomUUID()}.${fileExt}`;
            const filePath = `${user.id}/${fileName}`;

            const { error: uploadError } = await supabase.storage
                .from("listings")
                .upload(filePath, imageFile);

            if (uploadError) {
                error = `Błąd przesyłania zdjęcia: ${uploadError.message}`;
                break;
            } else {
                const { data } = supabase.storage
                    .from("listings")
                    .getPublicUrl(filePath);
                image_urls.push(data.publicUrl);
            }
        }

        if (!error) {
            const { error: insertError } = await supabase
                .from("listings")
                .insert({
                    title,
                    description,
                    price,
                    location,
                    category_id: category_id || null,
                    image_urls,
                    seller_id: user.id,
                    category_details,
                });

            if (insertError) {
                error = insertError.message;
            } else {
                success = true;
                return Astro.redirect("/dashboard");
            }
        }
    } else {
        error = "Title is required.";
    }
}
---

<Layout title="Dodaj Ogłoszenie | TARNÓW.TECH">
    <Header
        client:load
        user={user}
        profile={profile}
    />
    <div class="min-h-screen bg-paper text-ink pt-28 pb-16">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="mb-12 flex items-center justify-between">
                <a
                    href="/dashboard"
                    class="flex items-center gap-2 text-accent hover:text-ink transition-colors mono-label text-[10px] uppercase font-bold tracking-wider group"
                >
                    <ArrowLeft size={16} className="group-hover:-translate-x-1 transition-transform" /> Wróć do panelu
                </a>

                <div class="flex items-center gap-4">
                    <div id="step-indicator" class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-ink" id="dot-1"></div>
                        <div class="w-8 h-[1px] bg-line"></div>
                        <div class="w-2 h-2 rounded-full bg-line" id="dot-2"></div>
                    </div>
                    <span class="mono-label text-[10px] text-accent uppercase tracking-widest" id="step-text">Krok 1 z 2</span>
                </div>
            </div>

            {/* Step 1: Category Selection */}
            <div id="step-1" class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                <div class="text-center mb-12">
                    <span class="mono-label text-[10px] text-accent mb-3 block uppercase tracking-[0.2em]">Wybierz kategorię</span>
                    <h1 class="text-4xl font-bold text-ink tracking-tighter uppercase mb-4">Co chcesz ogłosić?</h1>
                    <p class="text-accent max-w-lg mx-auto text-sm font-medium">
                        Wybierz odpowiednią kategorię, abyśmy mogli dopasować formularz i wyświetlić Twoje ogłoszenie we właściwym miejscu.
                    </p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {categories?.map((cat) => {
                        let Icon = ClipboardList;
                        let desc = "Standardowe ogłoszenie lokalne";
                        
                        if (cat.slug === 'nieruchomosci') { 
                            Icon = Building2; 
                            desc = "Mieszkania, domy, stancje i pokoje bezpośrednio.";
                        }
                        if (cat.slug === 'praca') { 
                            Icon = Briefcase; 
                            desc = "Oferty pracy w gastronomii, handlu i usługach.";
                        }
                        if (cat.slug === 'uslugi') { 
                            Icon = Wrench; 
                            desc = "Fachowcy, remonty, korepetycje i uroda.";
                        }
                        if (cat.slug === 'oddam-zamienie') { 
                            Icon = Gift; 
                            desc = "Oddaj za darmo lub wymień się ze sąsiadami.";
                        }
                        if (cat.slug === 'motoryzacja') { 
                            Icon = Car; 
                            desc = "Samochody, skutery, części i opony lokalnie.";
                        }
                        if (cat.slug === 'drobne-zlecenia') { 
                            Icon = ClipboardList; 
                            desc = "Szybka pomoc, koszenie trawy, wywóz mebli.";
                        }

                        return (
                            <button
                                type="button"
                                class="category-card group bg-white border border-line p-8 text-left hover:border-ink transition-all duration-300 relative overflow-hidden flex flex-col items-start gap-4 shadow-sm hover:shadow-2xl hover:shadow-ink/5"
                                data-id={cat.id}
                                data-slug={cat.slug}
                                data-name={cat.name}
                            >
                                <div class="w-12 h-12 bg-paper border border-line flex items-center justify-center text-ink group-hover:bg-ink group-hover:text-white transition-all duration-300 rounded-none relative z-10">
                                    <Icon size={24} />
                                </div>
                                <div class="relative z-10">
                                    <h3 class="font-bold text-lg uppercase tracking-tight mb-2 group-hover:text-accent transition-colors">{cat.name}</h3>
                                    <p class="text-xs text-accent font-medium leading-relaxed opacity-80 group-hover:opacity-100">{desc}</p>
                                </div>
                                <div class="absolute -bottom-4 -right-4 text-line/20 group-hover:text-accent/10 transition-colors pointer-events-none transform -rotate-12 translate-x-2 translate-y-2 group-hover:translate-x-0 group-hover:translate-y-0 duration-700">
                                    <Icon size={120} />
                                </div>
                            </button>
                        )
                    })}
                </div>
            </div>

            {/* Step 2: Listing Form */}
            <div id="step-2" class="hidden">
                <div class="bg-white border border-line shadow-2xl relative animate-in fade-in zoom-in-95 duration-500">
                    <div class="absolute top-0 left-0 w-2 h-full bg-ink"></div>
                    
                    <div class="p-8 md:p-10 border-b border-line flex items-center justify-between">
                         <div class="flex items-center gap-6">
                            <button id="back-to-step-1" class="flex items-center justify-center w-10 h-10 border border-line hover:border-ink hover:bg-paper transition-all">
                                <ArrowLeft size={18} />
                            </button>
                            <div>
                                <span class="mono-label text-[10px] text-accent mb-1 block flex items-center gap-2">
                                    KREATYOR OGŁOSZENIA / <span id="selected-category-name" class="text-ink font-bold">MOTORYZACJA</span>
                                </span>
                                <h2 class="text-2xl font-bold text-ink tracking-tighter uppercase">Szczegóły Ogłoszenia</h2>
                            </div>
                         </div>
                         <div class="hidden sm:block">
                            <CheckCircle2 size={32} class="text-line" />
                         </div>
                    </div>

                    <form
                        id="listing-form"
                        method="POST"
                        enctype="multipart/form-data"
                        class="p-8 md:p-10 space-y-8"
                    >
                        <input type="hidden" name="category_id" id="hidden-category-id" />
                        
                        {error && (
                            <div class="bg-red-50 border-l-2 border-red-500 text-ink p-4 text-[11px] font-medium animate-in fade-in slide-in-from-top-2">
                                BŁĄD SYSTEMU: {error}
                            </div>
                        )}

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                            <div class="md:col-span-2">
                                <label class="mono-label text-[10px] block text-accent mb-2 uppercase tracking-wider font-bold">Podstawy</label>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="md:col-span-2">
                                        <input
                                            type="text"
                                            name="title"
                                            required
                                            class="w-full bg-paper border border-line px-6 py-4 text-sm text-ink focus:outline-none focus:border-ink transition-all font-medium placeholder:opacity-30"
                                            placeholder="Tytuł ogłoszenia (np. Mieszkanie po remoncie)"
                                        />
                                    </div>
                                    <div class="md:col-span-2">
                                        <textarea
                                            name="description"
                                            rows={5}
                                            class="w-full bg-paper border border-line px-6 py-4 text-sm text-ink focus:outline-none focus:border-ink transition-all font-medium resize-none placeholder:opacity-30"
                                            placeholder="Opisz dokładnie swój przedmiot lub usługę..."
                                        ></textarea>
                                    </div>
                                    <div class="relative group">
                                        <div class="absolute left-6 top-1/2 -translate-y-1/2 text-accent font-bold text-xs pointer-events-none group-focus-within:text-ink transition-colors">PLN</div>
                                        <input
                                            type="text"
                                            name="price"
                                            class="w-full bg-paper border border-line pl-16 pr-6 py-4 text-sm text-ink focus:outline-none focus:border-ink transition-all font-bold"
                                            placeholder="Cena"
                                        />
                                    </div>
                                    <div class="relative group">
                                        <div class="absolute left-6 top-1/2 -translate-y-1/2 text-accent pointer-events-none group-focus-within:text-ink transition-colors">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                        </div>
                                        <input
                                            type="text"
                                            name="location"
                                            class="w-full bg-paper border border-line pl-16 pr-6 py-4 text-sm text-ink focus:outline-none focus:border-ink transition-all font-medium"
                                            placeholder="Lokalizacja (np. Tarnów)"
                                        />
                                    </div>
                                </div>
                            </div>

                            {/* Dynamic Category Fields */}
                            <div id="category-fields-container" class="md:col-span-2 space-y-4">
                                <label class="mono-label text-[10px] block text-accent mb-2 uppercase tracking-wider font-bold">Informacje Parametryczne</label>
                                <div id="dynamic-fields" class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-paper/50 p-8 border border-dashed border-line">
                                    {/* Populated via JS */}
                                </div>
                            </div>

                            <div class="md:col-span-2">
                                <label class="mono-label text-[10px] block text-accent mb-4 uppercase tracking-wider font-bold">Zdjęcia ogłoszenia <span class="text-line">(max. 3 sztuki)</span></label>

                                {/* Drop Zone */}
                                <div
                                    id="drop-zone"
                                    class="relative border-2 border-dashed border-line bg-paper/50 p-10 text-center cursor-pointer transition-all duration-300 hover:border-ink hover:bg-paper group"
                                >
                                    <input
                                        type="file"
                                        id="file-input"
                                        name="images"
                                        accept="image/*,image/heic,image/heif"
                                        multiple
                                        class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                                    />
                                    <div id="drop-zone-content" class="pointer-events-none flex flex-col items-center gap-4">
                                        <div class="w-16 h-16 border border-line bg-white flex items-center justify-center group-hover:border-ink transition-all duration-300">
                                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent group-hover:text-ink transition-colors">
                                                <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/>
                                                <path d="M12 12v9"/><path d="m16 16-4-4-4 4"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <p class="text-sm font-bold text-ink">Przeciągnij zdjęcia tutaj</p>
                                            <p class="text-xs text-accent mt-1">lub <span class="underline cursor-pointer group-hover:text-ink">kliknij, aby wybrać pliki</span></p>
                                        </div>
                                        <p class="mono-label text-[9px] text-accent uppercase tracking-widest">
                                            JPG, PNG, WEBP, HEIC — do 10 MB każde · max. 3 zdjęcia
                                        </p>
                                    </div>
                                </div>

                                {/* Preview Grid */}
                                <div id="preview-grid" class="grid grid-cols-3 gap-4 mt-4 hidden">
                                    {/* Filled by JS */}
                                </div>
                                <div id="upload-counter" class="hidden mt-3 mono-label text-[10px] text-accent uppercase tracking-wider flex items-center gap-2">
                                    <span id="count-text"></span>
                                    <span id="count-bar" class="flex gap-1">
                                        <span class="w-4 h-1 bg-line" id="bar-1"></span>
                                        <span class="w-4 h-1 bg-line" id="bar-2"></span>
                                        <span class="w-4 h-1 bg-line" id="bar-3"></span>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="pt-12 border-t border-line flex flex-col sm:flex-row items-center justify-between gap-6">
                            <p class="text-[10px] mono-label text-accent uppercase max-w-xs leading-relaxed">
                                Wysyłając formularz akceptujesz regulamin platformy <span class="text-ink">TARNÓW.TECH</span>. Ogłoszenie zostanie zindeksowane natychmiastowo.
                            </p>
                            <button
                                type="submit"
                                class="w-full sm:w-auto flex items-center justify-center gap-3 bg-ink text-white py-5 px-12 text-xs font-bold uppercase tracking-widest hover:bg-accent transition-all duration-300 shadow-2xl shadow-ink/20 group"
                            >
                                <Save size={18} className="group-hover:rotate-12 transition-transform" /> Publikuj Ogłoszenie
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .category-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: var(--color-ink);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.4s ease;
    }
    .category-card:hover::before {
        transform: scaleX(1);
    }
</style>

<script>
    const step1 = document.getElementById('step-1');
    const step2 = document.getElementById('step-2');
    const categoryCards = document.querySelectorAll('.category-card');
    const backBtn = document.getElementById('back-to-step-1');
    const hiddenCatId = document.getElementById('hidden-category-id') as HTMLInputElement;
    const catNameDisplay = document.getElementById('selected-category-name');
    const dynamicFields = document.getElementById('dynamic-fields');
    
    // Step indicator elements
    const dot2 = document.getElementById('dot-2');
    const stepText = document.getElementById('step-text');

    const CATEGORY_FIELDS: Record<string, any[]> = {
        'nieruchomosci': [
            { name: 'sub_category', label: 'Typ ogłoszenia', type: 'select', options: ['Wynajem długoterminowy', 'Sprzedaż', 'Stancje/Pokoje'] },
            { name: 'area', label: 'Powierzchnia (m²)', type: 'text', placeholder: 'np. 45' },
            { name: 'rooms', label: 'Liczba pokoi', type: 'number', placeholder: 'np. 2' },
            { name: 'floor', label: 'Piętro', type: 'text', placeholder: 'np. 3/4' },
        ],
        'praca': [
            { name: 'sub_category', label: 'Branża', type: 'select', options: ['Gastronomia', 'Praca fizyczna', 'Praca dodatkowa/uczniowska', 'Handel', 'Usługi'] },
            { name: 'salary', label: 'Wynagrodzenie', type: 'text', placeholder: 'np. 25-30 zł/h lub 5000 brutto' },
            { name: 'contract_type', label: 'Typ umowy', type: 'select', options: ['Umowa o pracę', 'Umowa zlecenie/o dzieło', 'B2B', 'Inna'] },
        ],
        'uslugi': [
            { name: 'sub_category', label: 'Typ usługi', type: 'select', options: ['Remonty', 'Naprawa sprzętu', 'Korepetycje', 'Uroda', 'Ogród', 'Transport'] },
            { name: 'experience', label: 'Doświadczenie', type: 'text', placeholder: 'np. 5 lat' },
        ],
        'oddam-zamienie': [
            { name: 'type', label: 'Rodzaj', type: 'select', options: ['Oddam za darmo', 'Zamienię'] },
            { name: 'condition', label: 'Stan', type: 'select', options: ['Nowy', 'Używany (idealny)', 'Używany (widoczne ślady)', 'Do odświeżenia/naprawy'] },
        ],
        'motoryzacja': [
            { name: 'brand', label: 'Marka i Model', type: 'text', placeholder: 'np. VW Golf VII' },
            { name: 'year', label: 'Rok produkcji', type: 'number', placeholder: 'np. 2015' },
            { name: 'mileage', label: 'Przebieg (km)', type: 'number', placeholder: 'np. 150000' },
            { name: 'fuel', label: 'Paliwo', type: 'select', options: ['Benzyna', 'Diesel', 'LPG', 'Hybryda', 'Elektryczny'] },
        ],
        'drobne-zlecenia': [
            { name: 'task_type', label: 'Rodzaj zlecenia', type: 'select', options: ['Jednorazowe', 'Cykliczne', 'Szybka pomoc'] },
            { name: 'deadline', label: 'Termin realizacji', type: 'text', placeholder: 'np. Jak najszybciej / Sobota rano' },
            { name: 'time_estimate', label: 'Szacowany czas', type: 'text', placeholder: 'np. 2-3 godziny' },
        ]
    };

    function renderFields(slug: string) {
        if (!dynamicFields) return;

        const fields = CATEGORY_FIELDS[slug];
        if (!fields) {
            dynamicFields.innerHTML = '<p class="text-accent text-xs italic opacity-50">Ta kategoria nie wymaga dodatkowych danych.</p>';
            return;
        }

        dynamicFields.innerHTML = fields.map(field => {
            const inputName = `details_${field.name}`;
            let inputHtml = '';

            if (field.type === 'select') {
                inputHtml = `
                    <div class="relative">
                        <select name="${inputName}" class="w-full bg-white border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-ink transition-all font-medium appearance-none cursor-pointer">
                            ${field.options.map((opt: string) => `<option value="${opt}">${opt}</option>`).join('')}
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-accent">
                            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"></path></svg>
                        </div>
                    </div>
                `;
            } else {
                inputHtml = `
                    <input type="${field.type}" name="${inputName}" placeholder="${field.placeholder || ''}" class="w-full bg-white border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-ink transition-all font-medium" />
                `;
            }

            return `
                <div class="${field.fullWidth ? 'md:col-span-2' : ''}">
                    <label class="mono-label text-[10px] block text-accent mb-2 uppercase tracking-wider font-bold">${field.label}</label>
                    ${inputHtml}
                </div>
            `;
        }).join('');
    }

    categoryCards.forEach(card => {
        card.addEventListener('click', () => {
            const id = (card as HTMLElement).dataset.id;
            const slug = (card as HTMLElement).dataset.slug;
            const name = (card as HTMLElement).dataset.name;

            if (id && slug && name) {
                // Update hidden inputs and labels
                hiddenCatId.value = id;
                if (catNameDisplay) catNameDisplay.innerText = name;
                
                // Render dynamic fields
                renderFields(slug);

                // Switch steps
                step1?.classList.add('hidden');
                step2?.classList.remove('hidden');
                
                // Update indicator
                dot2?.classList.replace('bg-line', 'bg-ink');
                if (stepText) stepText.innerText = 'Krok 2 z 2';
                
                // Scroll to top
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });
    });

    backBtn?.addEventListener('click', () => {
        step2?.classList.add('hidden');
        step1?.classList.remove('hidden');
        
        // Update indicator
        dot2?.classList.replace('bg-ink', 'bg-line');
        if (stepText) stepText.innerText = 'Krok 1 z 2';
    });

    // ============================================================
    // Drag & Drop Image Upload Logic
    // ============================================================
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const previewGrid = document.getElementById('preview-grid');
    const uploadCounter = document.getElementById('upload-counter');
    const countText = document.getElementById('count-text');
    const MAX_FILES = 3;

    let selectedFiles: File[] = [];

    function updateCounter() {
        if (!uploadCounter || !countText) return;
        const n = selectedFiles.length;
        uploadCounter.classList.toggle('hidden', n === 0);
        countText.textContent = `${n} z ${MAX_FILES} zdjęć`;
        for (let i = 1; i <= MAX_FILES; i++) {
            const bar = document.getElementById(`bar-${i}`);
            if (bar) {
                bar.className = `w-4 h-1 ${i <= n ? 'bg-ink' : 'bg-line'}`;
            }
        }
    }

    function updateDropZoneState() {
        if (!dropZone) return;
        const full = selectedFiles.length >= MAX_FILES;
        dropZone.style.opacity = full ? '0.4' : '1';
        dropZone.style.pointerEvents = full ? 'none' : '';
        if (fileInput) fileInput.disabled = full;
    }

    function buildDataTransfer(files: File[]): DataTransfer {
        const dt = new DataTransfer();
        files.forEach(f => dt.items.add(f));
        return dt;
    }

    function renderPreviews() {
        if (!previewGrid) return;
        previewGrid.innerHTML = '';
        previewGrid.classList.toggle('hidden', selectedFiles.length === 0);

        selectedFiles.forEach((file, idx) => {
            const url = URL.createObjectURL(file);
            const card = document.createElement('div');
            card.className = 'relative aspect-[4/3] border border-line bg-paper overflow-hidden group';

            const img = document.createElement('img');
            img.src = url;
            img.alt = file.name;
            img.className = 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105';

            const overlay = document.createElement('div');
            overlay.className = 'absolute inset-0 bg-ink/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center gap-2 p-2';

            const name = document.createElement('p');
            name.className = 'text-white text-[9px] mono-label text-center leading-tight truncate w-full px-2';
            name.textContent = file.name;

            const size = document.createElement('p');
            size.className = 'text-white/60 text-[8px] mono-label';
            size.textContent = `${(file.size / 1024 / 1024).toFixed(1)} MB`;

            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'mt-1 flex items-center gap-1 text-red-300 hover:text-red-100 text-[9px] mono-label uppercase tracking-widest transition-colors';
            removeBtn.innerHTML = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg> Usuń`;
            removeBtn.addEventListener('click', () => {
                URL.revokeObjectURL(url);
                selectedFiles.splice(idx, 1);
                if (fileInput) fileInput.files = buildDataTransfer(selectedFiles).files;
                renderPreviews();
                updateCounter();
                updateDropZoneState();
            });

            overlay.append(name, size, removeBtn);
            card.append(img, overlay);

            if (idx === 0) {
                const badge = document.createElement('div');
                badge.className = 'absolute top-2 left-2 bg-ink text-white mono-label text-[8px] px-2 py-[2px] uppercase tracking-widest';
                badge.textContent = 'Główne';
                card.appendChild(badge);
            }

            previewGrid?.appendChild(card);
        });
    }

    function addFiles(newFiles: File[]) {
        const remaining = MAX_FILES - selectedFiles.length;
        const toAdd = newFiles.slice(0, remaining);
        selectedFiles = [...selectedFiles, ...toAdd];
        if (fileInput) fileInput.files = buildDataTransfer(selectedFiles).files;
        renderPreviews();
        updateCounter();
        updateDropZoneState();

        if (newFiles.length > remaining) {
            const skipped = newFiles.length - remaining;
            const msg = document.createElement('p');
            msg.className = 'mono-label text-[10px] text-red-500 mt-2 uppercase tracking-wider';
            msg.textContent = `Pominięto ${skipped} ${skipped === 1 ? 'zdjęcie' : 'zdjęcia'} — osiągnięto limit 3 plików.`;
            uploadCounter?.after(msg);
            setTimeout(() => msg.remove(), 3500);
        }
    }

    fileInput?.addEventListener('change', () => {
        if (!fileInput.files) return;
        addFiles(Array.from(fileInput.files));
    });

    dropZone?.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('border-ink', 'bg-paper');
        dropZone.classList.remove('border-line');
    });

    dropZone?.addEventListener('dragleave', () => {
        dropZone.classList.remove('border-ink', 'bg-paper');
        dropZone.classList.add('border-line');
    });

    dropZone?.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('border-ink', 'bg-paper');
        dropZone.classList.add('border-line');
        const files = Array.from(e.dataTransfer?.files || []).filter(f => f.type.startsWith('image/'));
        addFiles(files);
    });
</script>
