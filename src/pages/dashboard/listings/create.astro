---
import Layout from "../../../layouts/Layout.astro";
import { ArrowLeft, Save } from "lucide-react";

const { supabase, user } = Astro.locals;
if (!user) {
    return Astro.redirect("/login");
}

let error = "";
let success = false;

// Fetch categories for the select input
const { data: categories } = await supabase
    .from("categories")
    .select("id, name, slug");

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const title = formData.get("title")?.toString();
    const description = formData.get("description")?.toString();
    const price = formData.get("price")?.toString();
    const location = formData.get("location")?.toString();
    const category_id = formData.get("category_id")?.toString();
    const imageFiles = formData.getAll("images") as File[];
    let image_urls: string[] = [];

    // Extract category-specific details
    const category_details: Record<string, any> = {};
    for (const [key, value] of formData.entries()) {
        if (key.startsWith("details_")) {
            const fieldName = key.replace("details_", "");
            category_details[fieldName] = value;
        }
    }

    if (title) {
        // Handle up to 3 images
        const validImages = imageFiles
            .filter((file) => file.size > 0)
            .slice(0, 3);

        for (const imageFile of validImages) {
            const fileExt = imageFile.name.split(".").pop() || "jpg";
            const fileName = `${crypto.randomUUID()}.${fileExt}`;
            const filePath = `${user.id}/${fileName}`;

            const { error: uploadError } = await supabase.storage
                .from("listings")
                .upload(filePath, imageFile);

            if (uploadError) {
                error = `Błąd przesyłania zdjęcia: ${uploadError.message}`;
                break;
            } else {
                const { data } = supabase.storage
                    .from("listings")
                    .getPublicUrl(filePath);
                image_urls.push(data.publicUrl);
            }
        }

        if (!error) {
            const { error: insertError } = await supabase
                .from("listings")
                .insert({
                    title,
                    description,
                    price,
                    location,
                    category_id: category_id || null,
                    image_urls,
                    seller_id: user.id,
                    category_details,
                });

            if (insertError) {
                error = insertError.message;
            } else {
                success = true;
                return Astro.redirect("/dashboard");
            }
        }
    } else {
        error = "Title is required.";
    }
}
---

<Layout title="Dodaj Ogłoszenie | TARNÓW.TECH">
    <div class="min-h-screen bg-paper text-ink pt-28 pb-16">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="mb-8 flex items-center justify-between">
                <a
                    href="/dashboard"
                    class="flex items-center gap-2 text-accent hover:text-ink transition-colors mono-label text-[10px] uppercase font-bold tracking-wider"
                >
                    <ArrowLeft size={16} /> Wróć do panelu
                </a>
            </div>

            <div class="bg-white border border-line shadow-xl relative">
                {/* Decorative Elements */}
                <div class="absolute top-0 left-0 w-2 h-full bg-ink"></div>
                <div
                    class="absolute top-0 right-0 w-16 h-16 border-t border-r border-line opacity-50 pointer-events-none"
                >
                </div>

                <div class="p-8 md:p-10 border-b border-line">
                    <div class="flex items-start justify-between">
                        <div>
                            <span
                                class="mono-label text-[10px] text-accent mb-2 block"
                                >Kreator Ogłoszenia</span
                            >
                            <h1
                                class="text-3xl font-bold text-ink tracking-tighter uppercase"
                            >
                                Nowe Ogłoszenie
                            </h1>
                            <p class="text-accent mt-2 text-sm font-medium">
                                Wypełnij poniższy formularz, aby opublikować
                                swoje zgłoszenie w systemie.
                            </p>
                        </div>
                        <div
                            class="hidden sm:flex items-center justify-center w-12 h-12 bg-paper border border-line text-ink rounded-none"
                        >
                            <span class="font-mono text-xs font-bold">+</span>
                        </div>
                    </div>
                </div>

                <form
                    id="listing-form"
                    method="POST"
                    enctype="multipart/form-data"
                    class="p-8 md:p-10 space-y-8"
                >
                    {
                        error && (
                            <div class="bg-red-50 border-l-2 border-red-500 text-ink p-4 text-[11px] font-medium animate-in fade-in slide-in-from-top-2">
                                BŁĄD SYSTEMU: {error}
                            </div>
                        )
                    }

                    <div
                        class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6"
                    >
                        <div class="md:col-span-2">
                            <label
                                class="mono-label text-[10px] block text-accent mb-2"
                                >Tytuł Ogłoszenia <span class="text-red-500"
                                    >*</span
                                >
                            </label>
                            <input
                                type="text"
                                name="title"
                                required
                                class="w-full bg-paper border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-accent transition-all font-medium"
                                placeholder="np. iPhone 13 Pro Max - Idealny stan"
                            />
                        </div>

                        <div class="md:col-span-2">
                            <label
                                class="mono-label text-[10px] block text-accent mb-2"
                                >Opis Szczegółowy</label
                            >
                            <textarea
                                name="description"
                                rows={5}
                                class="w-full bg-paper border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-accent transition-all font-medium resize-none"
                                placeholder="Opisz przedmiot, jego stan, historię..."
                            ></textarea>
                        </div>

                        <div>
                            <label
                                class="mono-label text-[10px] block text-accent mb-2"
                                >Cena</label
                            >
                            <input
                                type="text"
                                name="price"
                                class="w-full bg-paper border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-accent transition-all font-medium"
                                placeholder="np. 2 850 PLN"
                            />
                        </div>

                        <div>
                            <label
                                class="mono-label text-[10px] block text-accent mb-2"
                                >Lokalizacja</label
                            >
                            <input
                                type="text"
                                name="location"
                                class="w-full bg-paper border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-accent transition-all font-medium"
                                placeholder="np. Tarnów, Centrum"
                            />
                        </div>

                        <div class="md:col-span-2">
                            <label
                                class="mono-label text-[10px] block text-accent mb-2"
                                >Kategoria</label
                            >
                            <div class="relative">
                                <select
                                    id="category-select"
                                    name="category_id"
                                    class="w-full bg-paper border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-accent transition-all font-medium appearance-none cursor-pointer"
                                >
                                    <option value=""
                                        >Wybierz kategorię...</option
                                    >
                                    {
                                        categories?.map((cat) => (
                                            <option value={cat.id} data-slug={cat.slug}>
                                                {cat.name}
                                            </option>
                                        ))
                                    }
                                </select>
                                <div
                                    class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-accent"
                                >
                                    <svg
                                        class="fill-current h-4 w-4"
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 20 20"
                                        ><path
                                            d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                        </div>

                        {/* Dynamic Category Fields */}
                        <div id="category-fields-container" class="md:col-span-2 hidden animate-in fade-in slide-in-from-top-4 duration-500">
                             <div class="h-px bg-line w-full my-4"></div>
                             <div id="dynamic-fields" class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                                 {/* Will be populated by JS */}
                             </div>
                        </div>

                        <div class="md:col-span-2">
                            <label
                                class="mono-label text-[10px] block text-accent mb-2"
                                >Zdjęcia (Galeria)</label
                            >
                            <input
                                type="file"
                                name="images"
                                accept="image/*"
                                multiple
                                class="w-full bg-paper border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-accent transition-all font-medium file:mr-4 file:py-2 file:px-4 file:border-0 file:text-sm file:font-semibold file:bg-ink file:text-white hover:file:bg-accent file:transition-all file:cursor-pointer"
                            />
                            <p class="text-[10px] mono-label text-accent mt-2">
                                Możesz przesłać do 3 zdjęć (max 5MB każda).
                            </p>
                        </div>
                    </div>

                    <div
                        class="pt-8 border-t border-line flex flex-col sm:flex-row items-center justify-between gap-4"
                    >
                        <span
                            class="text-[10px] mono-label text-accent uppercase"
                        >
                            Ogłoszenie zostanie opublikowane natychmiastowo.
                        </span>
                        <button
                            type="submit"
                            class="w-full sm:w-auto flex items-center justify-center gap-2 bg-ink text-white py-4 px-8 text-xs font-bold uppercase tracking-widest hover:bg-accent transition-all duration-300 shadow-lg shadow-ink/10"
                        >
                            <Save size={16} /> Publikuj Ogłoszenie
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</Layout>

<script>
    const categorySelect = document.getElementById('category-select') as HTMLSelectElement;
    const fieldsContainer = document.getElementById('category-fields-container');
    const dynamicFields = document.getElementById('dynamic-fields');

    const CATEGORY_FIELDS: Record<string, any[]> = {
        'nieruchomosci': [
            { name: 'sub_category', label: 'Typ ogłoszenia', type: 'select', options: ['Wynajem długoterminowy', 'Sprzedaż', 'Stancje/Pokoje'] },
            { name: 'area', label: 'Powierzchnia (m²)', type: 'text', placeholder: 'np. 45' },
            { name: 'rooms', label: 'Liczba pokoi', type: 'number', placeholder: 'np. 2' },
            { name: 'floor', label: 'Piętro', type: 'text', placeholder: 'np. 3/4' },
        ],
        'praca': [
            { name: 'sub_category', label: 'Branża', type: 'select', options: ['Gastronomia', 'Praca fizyczna', 'Praca dodatkowa/uczniowska', 'Handel', 'Usługi'] },
            { name: 'salary', label: 'Wynagrodzenie', type: 'text', placeholder: 'np. 25-30 zł/h lub 5000 brutto' },
            { name: 'contract_type', label: 'Typ umowy', type: 'select', options: ['Umowa o pracę', 'Umowa zlecenie/o dzieło', 'B2B', 'Inna'] },
        ],
        'uslugi': [
            { name: 'sub_category', label: 'Typ usługi', type: 'select', options: ['Remonty', 'Naprawa sprzętu', 'Korepetycje', 'Uroda', 'Ogród', 'Transport'] },
            { name: 'experience', label: 'Doświadczenie', type: 'text', placeholder: 'np. 5 lat' },
        ],
        'oddam-zamienie': [
            { name: 'type', label: 'Rodzaj', type: 'select', options: ['Oddam za darmo', 'Zamienię'] },
            { name: 'condition', label: 'Stan', type: 'select', options: ['Nowy', 'Używany (idealny)', 'Używany (widoczne ślady)', 'Do odświeżenia/naprawy'] },
        ],
        'motoryzacja': [
            { name: 'brand', label: 'Marka i Model', type: 'text', placeholder: 'np. VW Golf VII' },
            { name: 'year', label: 'Rok produkcji', type: 'number', placeholder: 'np. 2015' },
            { name: 'mileage', label: 'Przebieg (km)', type: 'number', placeholder: 'np. 150000' },
            { name: 'fuel', label: 'Paliwo', type: 'select', options: ['Benzyna', 'Diesel', 'LPG', 'Hybryda', 'Elektryczny'] },
        ],
        'drobne-zlecenia': [
            { name: 'task_type', label: 'Rodzaj zlecenia', type: 'select', options: ['Jednorazowe', 'Cykliczne', 'Szybka pomoc'] },
            { name: 'deadline', label: 'Termin realizacji', type: 'text', placeholder: 'np. Jak najszybciej / Sobota rano' },
            { name: 'time_estimate', label: 'Szacowany czas', type: 'text', placeholder: 'np. 2-3 godziny' },
        ]
    };

    function renderFields(slug: string) {
        if (!dynamicFields || !fieldsContainer) return;

        const fields = CATEGORY_FIELDS[slug];
        if (!fields) {
            fieldsContainer.classList.add('hidden');
            dynamicFields.innerHTML = '';
            return;
        }

        fieldsContainer.classList.remove('hidden');
        dynamicFields.innerHTML = fields.map(field => {
            const inputName = `details_${field.name}`;
            let inputHtml = '';

            if (field.type === 'select') {
                inputHtml = `
                    <div class="relative">
                        <select name="${inputName}" class="w-full bg-paper border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-accent transition-all font-medium appearance-none cursor-pointer">
                            ${field.options.map((opt: string) => `<option value="${opt}">${opt}</option>`).join('')}
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-accent">
                            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"></path></svg>
                        </div>
                    </div>
                `;
            } else {
                inputHtml = `
                    <input type="${field.type}" name="${inputName}" placeholder="${field.placeholder || ''}" class="w-full bg-paper border border-line px-4 py-3 text-sm text-ink focus:outline-none focus:border-accent transition-all font-medium" />
                `;
            }

            return `
                <div class="${field.fullWidth ? 'md:col-span-2' : ''}">
                    <label class="mono-label text-[10px] block text-accent mb-2 uppercase tracking-wider">${field.label}</label>
                    ${inputHtml}
                </div>
            `;
        }).join('');
    }

    categorySelect?.addEventListener('change', () => {
        const selectedOption = categorySelect.options[categorySelect.selectedIndex];
        const slug = selectedOption.getAttribute('data-slug');
        renderFields(slug || '');
    });
</script>
