---
import Layout from "../../layouts/Layout.astro";
import { ArrowLeft, Save, Upload, User as UserIcon } from "lucide-react";
import { UserAvatar } from "../../components/UserAvatar";

const { supabase, user } = Astro.locals;
if (!user) {
    return Astro.redirect("/login");
}

let error = "";
let success = false;

// Fetch current profile
let { data: profile } = await supabase
    .from("profiles")
    .select("*")
    .eq("id", user.id)
    .single();

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const username = formData.get("username")?.toString();
    const full_name = formData.get("full_name")?.toString();
    
    const avatarFile = formData.get("avatar") as File;
    let avatar_url = profile?.avatar_url;

    if (avatarFile && avatarFile.size > 0) {
        const fileExt = avatarFile.name.split(".").pop();
        const fileName = `${user.id}-${Math.random().toString(36).substring(2)}.${fileExt}`;
        const filePath = `${fileName}`;

        const { error: uploadError } = await supabase.storage
            .from("avatars")
            .upload(filePath, avatarFile, { upsert: true });

        if (uploadError) {
            error = `Błąd przesyłania awatara: ${uploadError.message}`;
        } else {
            const { data: publicUrlData } = supabase.storage
                .from("avatars")
                .getPublicUrl(filePath);
            avatar_url = publicUrlData.publicUrl;
        }
    }

    if (!error) {
        const updates = {
            id: user.id,
            username,
            full_name,
            avatar_url,
        };

        const { error: updateError } = await supabase
            .from("profiles")
            .upsert(updates);

        if (updateError) {
            error = updateError.message;
        } else {
            success = true;
            profile = { ...profile, ...updates };
        }
    }
}
---

<Layout title="Profile Settings">
    <div class="min-h-screen bg-slate-950 text-slate-200 py-8">
        <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="mb-6 flex items-center justify-between">
                <a
                    href="/dashboard"
                    class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors"
                >
                    <ArrowLeft size={18} /> Back to Dashboard
                </a>
            </div>

            <div
                class="bg-slate-900 border border-slate-800 rounded-2xl shadow-xl overflow-hidden"
            >
                <div
                    class="p-6 md:p-8 border-b border-slate-800 bg-slate-800/20"
                >
                    <h1 class="text-2xl font-bold text-white">
                        Profile Settings
                    </h1>
                    <p class="text-slate-400 mt-1">
                        Manage your public profile information.
                    </p>
                </div>

                <form method="POST" enctype="multipart/form-data" class="p-6 md:p-8 space-y-6">
                    {
                        error && (
                            <div class="bg-red-500/10 border border-red-500/50 text-red-400 p-4 rounded-xl text-sm">
                                {error}
                            </div>
                        )
                    }

                    {
                        success && (
                            <div class="bg-emerald-500/10 border border-emerald-500/50 text-emerald-400 p-4 rounded-xl text-sm">
                                Profile updated successfully!
                            </div>
                        )
                    }

                    <div class="space-y-8">
                        {/* Avatar Section */}
                        <div class="flex flex-col sm:flex-row items-center gap-8 p-6 bg-slate-950 border border-slate-700 rounded-2xl">
                            <div class="relative group">
                                <UserAvatar 
                                    url={profile?.avatar_url} 
                                    fallback={profile?.full_name || user.email}
                                    size="lg"
                                    className="ring-4 ring-slate-800"
                                />
                                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center pointer-events-none">
                                    <Upload size={20} className="text-white" />
                                </div>
                            </div>
                            <div class="flex-grow space-y-3 text-center sm:text-left">
                                <h3 class="text-lg font-semibold text-white">Twoje zdjęcie profilowe</h3>
                                <p class="text-sm text-slate-400">Prześlij zdjęcie, aby inni mogli Cię rozpoznać.</p>
                                <label class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-white text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-lg cursor-pointer transition-all">
                                    <Upload size={14} />
                                    <span>Wybierz plik</span>
                                    <input type="file" name="avatar" accept="image/*" class="hidden" id="avatar-input" />
                                </label>
                                <div id="file-name" class="text-[10px] mono-label text-blue-400 h-4 uppercase"></div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="md:col-span-2">
                                <label
                                    class="block text-sm font-medium text-slate-300 mb-2 uppercase tracking-tight"
                                    >Email (Tylko do odczytu)</label
                                >
                                <input
                                    type="email"
                                    value={user.email}
                                    disabled
                                    class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-slate-500 cursor-not-allowed font-medium"
                                />
                            </div>

                            <div>
                                <label
                                    class="block text-sm font-medium text-slate-300 mb-2 uppercase tracking-tight"
                                    >Nazwa użytkownika</label
                                >
                                <input
                                    type="text"
                                    name="username"
                                    value={profile?.username || ""}
                                    class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all font-medium"
                                    placeholder="np. jan_kowalski"
                                />
                            </div>

                            <div>
                                <label
                                    class="block text-sm font-medium text-slate-300 mb-2 uppercase tracking-tight"
                                    >Imię i Nazwisko</label
                                >
                                <input
                                    type="text"
                                    name="full_name"
                                    value={profile?.full_name || ""}
                                    class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all font-medium"
                                    placeholder="Jan Kowalski"
                                />
                            </div>
                        </div>
                    </div>

                    <div
                        class="pt-6 border-t border-slate-800 flex justify-end"
                    >
                        <button
                            type="submit"
                            class="flex items-center gap-2 bg-gradient-to-r from-blue-500 to-purple-500 hover:from-blue-400 hover:to-purple-400 text-white font-medium px-6 py-3 rounded-xl transition-all shadow-lg shadow-blue-500/20"
                        >
                            <Save size={18} /> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</Layout>

<script>
    const avatarInput = document.getElementById('avatar-input') as HTMLInputElement;
    const fileNameDisplay = document.getElementById('file-name');

    avatarInput?.addEventListener('change', (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file && fileNameDisplay) {
            fileNameDisplay.textContent = `Wybrano: ${file.name}`;
        }
    });
</script>
