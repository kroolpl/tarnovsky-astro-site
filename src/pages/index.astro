---
import Layout from "../layouts/Layout.astro";
import { Header } from "../components/Header";
import {
	FeaturedSection,
	type Announcement,
} from "../components/FeaturedSection";
import { SearchBar } from "../components/SearchBar";
import { LatestEntries } from "../components/LatestEntries";
import { PromotedSidebar } from "../components/PromotedSidebar";
import Footer from "../components/Footer.astro";

const { supabase, user, profile } = Astro.locals;

// Parse Search Parameters
const url = new URL(Astro.request.url);
const searchQ = url.searchParams.get('q');
const hasImages = url.searchParams.get('has_images') === 'true';
const isToday = url.searchParams.get('today') === 'true';
const isSearching = !!(searchQ || hasImages || isToday);

// Fetch Real Data from Supabase with Dynamic Filters
let query = supabase
	.from("listings")
	.select(`
		*,
		profiles (username, avatar_url),
		categories (name)
	`);

if (searchQ) {
	query = query.or(`title.ilike.%${searchQ}%,description.ilike.%${searchQ}%`);
}

if (hasImages) {
	// Filter for listings with at least one image
	query = query.not('image_urls', 'is', 'null');
}

if (isToday) {
	const todayStart = new Date();
	todayStart.setHours(0, 0, 0, 0);
	query = query.gte('created_at', todayStart.toISOString());
}

const { data: listings } = await query.order("created_at", { ascending: false });

// For "hasImages" we might need an additional client-side filter if the DB column is an empty array but not null
// However, Supabase not.is.null is a good start. Let's add a post-fetch filter for empty arrays just in case.
const filteredListings = listings?.filter(item => {
	if (hasImages && (!item.image_urls || item.image_urls.length === 0)) return false;
	return true;
}) || [];

const transformToListing = (item: any): Announcement => ({
	id: item.id,
	date: new Date(item.created_at).toISOString().split("T")[0],
	title: item.title,
	price: item.price,
	image_urls: item.image_urls || [],
	description: item.description,
	location: item.location,
	category: item.categories?.name || "Inne",
	seller: item.profiles?.username || "Anonim",
	seller_avatar: item.profiles?.avatar_url,
	featured: item.is_featured,
	tags: item.tags || [],
});

const featuredItems =
	filteredListings
		?.filter((l) => l.is_featured)
		.map(transformToListing)
		.slice(0, 3) || [];
const latestItems = filteredListings?.map(transformToListing) || [];
const promotedItems =
	filteredListings
		?.filter((l) => l.is_promoted)
		.map(transformToListing)
		.slice(0, 2) || [];
---

<Layout title={isSearching ? `Szukaj: ${searchQ || 'Filtry'}` : "Główna"}>
	<Header client:load user={user} profile={profile} />

	<main class="flex-grow">
		{!isSearching && <FeaturedSection items={featuredItems} client:visible />}
		<SearchBar client:load />

		<div
			class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col lg:flex-row gap-12 mb-16 sm:mb-24"
		>
			<LatestEntries 
				items={latestItems} 
				title={isSearching ? `Wyniki wyszukiwania (${latestItems.length})` : "Najnowsze wpisy"}
				client:load 
			/>
			
			{!isSearching && latestItems.length > 0 && (
				<PromotedSidebar items={promotedItems} client:visible />
			)}
		</div>
	</main>

	<Footer />
</Layout>
